rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getRole() in ['admin', 'superAdmin'];
    }

    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'superAdmin';
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────
    //
    // READ   : own document or any admin
    // CREATE : owner only; must set role='user', uid=<own uid>
    //          vehicleRegistered defaults to false — enforced here
    // UPDATE : owner can update any field EXCEPT role, uid, createdAt
    //          admins can update anything (e.g. suspend a user)
    // DELETE : superAdmin only

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.role == 'user'
        && request.resource.data.uid  == uid
        && request.resource.data.vehicleRegistered == false;

      allow update: if (
          isOwner(uid) &&
          !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['role', 'uid', 'createdAt'])
        ) || isAdmin();

      allow delete: if isSuperAdmin();

      // ── /users/{uid}/vehicles/{vehicleId} ─────────────────────────────────

      match /vehicles/{vehicleId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // ── /bookings/{bookingId} ─────────────────────────────────────────────────
    //
    // READ   : booking owner or admin
    // CREATE : authenticated user; userId must match auth.uid; status must be 'pending'
    // UPDATE : owner can only cancel their own pending booking (status field only)
    //          admins can update anything (status transitions, fare finalisation, etc.)
    // DELETE : admins only (for cleanup)

    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.userId      == request.auth.uid
        && request.resource.data.fare        is number
        && request.resource.data.fare        >  0
        && request.resource.data.status      == 'pending'
        && request.resource.data.bookingType in ['standard', 'immediate'];

      allow update: if isSignedIn() && (
        (
          // User can only cancel their own pending booking
          resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['status', 'updatedAt', '_serverTs'])
          && request.resource.data.status == 'cancelled'
          && resource.data.status         == 'pending'
        )
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── /fareRules/{ruleId} ───────────────────────────────────────────────────
    //
    // READ   : any authenticated user (needed at booking time for fare calculation)
    // WRITE  : admins only; enforce service type validity on create

    match /fareRules/{ruleId} {
      allow read: if isSignedIn();

      allow create: if isAdmin()
        && request.resource.data.serviceType in ['Distance', 'Immediate Distance', 'Hourly', 'Full Day']
        && request.resource.data.isActive     is bool
        && request.resource.data.name         is string
        && request.resource.data.name.size()  >  0;

      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── /appSettings/{docId} ─────────────────────────────────────────────────
    //
    // Stores bookingPolicy and other global config.
    // READ  : any authenticated user
    // WRITE : admins only

    match /appSettings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Catch-all deny ────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
