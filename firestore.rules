rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && getRole() in ['admin', 'superAdmin'];
    }
    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'superAdmin';
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.role == 'user'
        && request.resource.data.uid  == uid;
      allow update: if (
          isOwner(uid) &&
          !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['role', 'uid', 'createdAt'])
        ) || isAdmin();
      allow delete: if isSuperAdmin();

      match /vehicles/{vehicleId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // ── /bookings/{bookingId} ─────────────────────────────────────────────────

    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.fare   is number
        && request.resource.data.fare   >  0
        && request.resource.data.status == 'pending'
        && request.resource.data.bookingType in ['standard', 'immediate'];

      allow update: if isSignedIn() && (
        (
          resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['status', 'updatedAt', '_serverTs'])
          && request.resource.data.status == 'cancelled'
          && resource.data.status         == 'pending'
        )
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── /fareRules/{ruleId} ───────────────────────────────────────────────────
    // Fixed: added 'Immediate Distance' to the allowed serviceType list.
    // Without this, admins cannot create Immediate Distance fare rules.

    match /fareRules/{ruleId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin()
        && request.resource.data.serviceType in [
             'Distance',
             'Immediate Distance',
             'Hourly',
             'Full Day'
           ]
        && request.resource.data.isActive    is bool
        && request.resource.data.name        is string
        && request.resource.data.name.size() >  0;
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── /appSettings/{docId} ─────────────────────────────────────────────────

    match /appSettings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
